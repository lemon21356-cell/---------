{
  "manifest_version": 3,
  "name": "엔트리 블록 클린업 최종",
  "version": "1.4",
  "permissions": ["activeTab", "scripting"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["*://playentry.org/ws/*"],
      "js": ["content.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ]
}
